# Copy this file to .env and fill in your key.
# Only required for live runs; `--dry-run` needs no key at all.

ANTHROPIC_API_KEY=sk-ant-...

# --- Optional overrides (defaults shown) ---
# SUMMARIZER_MODEL=claude-sonnet-4-6
# EVALUATOR_MODEL=claude-opus-4-8
# MAX_TOKENS=2048
# TEMPERATURE=0.2

# Embeddings: "sentence-transformers" (default) or "hashing" (offline, no download)
# EMBEDDING_BACKEND=sentence-transformers
# EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# HASHING_DIM=512

# Retrieval / chunking
# CHUNK_SIZE=1100
# CHUNK_OVERLAP=150
# TOP_K=6
# MAX_ITERATIONS=3

# Storage
# INDEX_DIR=data/index
# RAW_DIR=data/raw

# Web service
# WEB_API_KEY=
# Comma-separated 'name:key' pairs for scoped access, e.g. "alice:sk-a,bob:sk-b"
# WEB_API_KEYS=
# Comma-separated allowed browser origins for the frontend, or "*" (default)
# CORS_ORIGINS=*
# Max /research calls per minute per caller (by API key or IP). 0 disables it.
# RATE_LIMIT_PER_MINUTE=20
# Hard wall-clock cap (seconds) on a single /research call before a 504.
# REQUEST_TIMEOUT_SECONDS=120
